module face_selector_support_mod_test

  use funit
  use constants_mod,         only : i_def, IMDI
  use reference_element_mod, only : W, S, E, N

  implicit none

  private
  public :: face_selector_test_type , test_compute_face_selector, test_face_from_face_selector

  @TestCase
  type, extends(TestCase) :: face_selector_test_type
    private
  contains
    procedure test_compute_face_selector
    procedure test_face_from_face_selector
  end type face_selector_test_type


contains

  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  @Test
  subroutine test_face_from_face_selector( this )

    use sci_face_selector_support_mod, only : face_from_face_selector

    implicit none

    class(face_selector_test_type), intent(inout) :: this

    integer(kind=i_def)              :: idx
    integer(kind=i_def)              :: face_selector_ew
    integer(kind=i_def)              :: face_selector_ns
    integer(kind=i_def)              :: face
    integer(kind=i_def)              :: answer(4)

    ! Test all individual cases
    ! (1, 0) -------------------------------------------------------------------
    face_selector_ew = 1
    face_selector_ns = 0
    answer = (/ W, IMDI, IMDI, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (0, 1) -------------------------------------------------------------------
    face_selector_ew = 0
    face_selector_ns = 1
    answer = (/ S, IMDI, IMDI, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (1, 1) -------------------------------------------------------------------
    face_selector_ew = 1
    face_selector_ns = 1
    answer = (/ W, S, IMDI, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (2, 0) -------------------------------------------------------------------
    face_selector_ew = 2
    face_selector_ns = 0
    answer = (/ W, E, IMDI, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (0, 2) -------------------------------------------------------------------
    face_selector_ew = 0
    face_selector_ns = 2
    answer = (/ S, N, IMDI, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (-1, 0) ------------------------------------------------------------------
    face_selector_ew = -1
    face_selector_ns = 0
    answer = (/ E, IMDI, IMDI, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (0, -1) ------------------------------------------------------------------
    face_selector_ew = 0
    face_selector_ns = -1
    answer = (/ N, IMDI, IMDI, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (-1, -1) ----------------------------------------------------------------
    face_selector_ew = -1
    face_selector_ns = -1
    answer = (/ E, N, IMDI, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (1, -1) ------------------------------------------------------------------
    face_selector_ew = 1
    face_selector_ns = -1
    answer = (/ W, N, IMDI, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (-1, 1) ------------------------------------------------------------------
    face_selector_ew = -1
    face_selector_ns = 1
    answer = (/ E, S, IMDI, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (2, -1) ------------------------------------------------------------------
    face_selector_ew = 2
    face_selector_ns = -1
    answer = (/ W, E, N, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (-1, 2) ------------------------------------------------------------------
    face_selector_ew = -1
    face_selector_ns = 2
    answer = (/ E, S, N, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (2, 2) -------------------------------------------------------------------
    face_selector_ew = 2
    face_selector_ns = 2
    answer = (/ W, E, S, N /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (2, 1) -------------------------------------------------------------------
    face_selector_ew = 2
    face_selector_ns = 1
    answer = (/ W, E, S, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

    ! (1, 2) -------------------------------------------------------------------
    face_selector_ew = 1
    face_selector_ns = 2
    answer = (/ W, S, N, IMDI /)
    do idx = 1, ABS(face_selector_ew) + ABS(face_selector_ns)
      face = face_from_face_selector(idx, face_selector_ew, face_selector_ns)
      @assertEqual(answer(idx), face)
    end do

  end subroutine test_face_from_face_selector

  !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
  @Test
  subroutine test_compute_face_selector( this )

    use sci_face_selector_support_mod, only : compute_face_selector

    implicit none

    class(face_selector_test_type), intent(inout) :: this

    integer(kind=i_def)              :: ndf_w3, ndf_w2h
    integer(kind=i_def)              :: undf_w3, undf_w2h
    integer(kind=i_def), allocatable :: map_w3(:), map_w2h(:)
    integer(kind=i_def), allocatable :: face_selector_ew(:)
    integer(kind=i_def), allocatable :: face_selector_ns(:)
    integer(kind=i_def), allocatable :: face_counter(:)
    integer(kind=i_def), allocatable :: face_selector_ew_answer(:)
    integer(kind=i_def), allocatable :: face_selector_ns_answer(:)
    integer(kind=i_def), allocatable :: face_counter_answer(:)

    ! Set integer values to describe mesh (single layer, single column)
    undf_w3 = 1
    ndf_w3 = 1
    undf_w2h = 4
    ndf_w2h = 4

    allocate(map_w3(undf_w3))
    allocate(map_w2h(undf_w2h))
    allocate(face_selector_ew(undf_w3))
    allocate(face_selector_ns(undf_w3))
    allocate(face_counter(undf_w2h))

    allocate(face_selector_ew_answer(undf_w3))
    allocate(face_selector_ns_answer(undf_w3))
    allocate(face_counter_answer(undf_w2h))

    ! DoF map
    map_w3 = (/ 1 /)
    map_w2h = (/ 1, 2, 3, 4 /)

    ! Test 1 -------------------------------------------------------------------
    ! If E and N faces already assigned to in face counter, nothing should happen
    face_selector_ew(1) = 1
    face_selector_ns(1) = 1
    face_counter = (/ 1, 1, 1, 1 /)
    face_selector_ew_answer = face_selector_ew
    face_selector_ns_answer = face_selector_ns
    face_counter_answer = face_counter

    call compute_face_selector( face_selector_ew, &
                                face_selector_ns, &
                                face_counter,     &
                                ndf_w3,           &
                                undf_w3,          &
                                map_w3,           &
                                ndf_w2h,          &
                                undf_w2h,         &
                                map_w2h )

    ! Check values!
    @assertEqual( face_selector_ew_answer, face_selector_ew )
    @assertEqual( face_selector_ns_answer, face_selector_ns )
    @assertEqual( face_counter_answer, face_counter )

    ! Test 2 -------------------------------------------------------------------
    ! E face already assigned to, but not N
    face_selector_ew(1) = 0
    face_selector_ns(1) = 0
    face_counter = (/ 1, 1, 1, 0 /)
    face_selector_ew_answer = face_selector_ew
    face_selector_ns_answer(1) = -1
    face_counter_answer = (/ 1, 1, 1, 1 /)

    call compute_face_selector( face_selector_ew, &
                                face_selector_ns, &
                                face_counter,     &
                                ndf_w3,           &
                                undf_w3,          &
                                map_w3,           &
                                ndf_w2h,          &
                                undf_w2h,         &
                                map_w2h )

    ! Check values!
    @assertEqual( face_selector_ew_answer, face_selector_ew )
    @assertEqual( face_selector_ns_answer, face_selector_ns )
    @assertEqual( face_counter_answer, face_counter )

    ! Test 3 -------------------------------------------------------------------
    ! N face already assigned to, but not E
    face_selector_ew(1) = 0
    face_selector_ns(1) = 0
    face_counter = (/ 1, 1, 0, 1 /)
    face_selector_ew_answer(1) = -1
    face_selector_ns_answer = face_selector_ns
    face_counter_answer = (/ 1, 1, 1, 1 /)

    call compute_face_selector( face_selector_ew, &
                                face_selector_ns, &
                                face_counter,     &
                                ndf_w3,           &
                                undf_w3,          &
                                map_w3,           &
                                ndf_w2h,          &
                                undf_w2h,         &
                                map_w2h )

    ! Check values!
    @assertEqual( face_selector_ew_answer, face_selector_ew )
    @assertEqual( face_selector_ns_answer, face_selector_ns )
    @assertEqual( face_counter_answer, face_counter )

    ! Test 4 -------------------------------------------------------------------
    ! If neither E or N faces are assigned, both should become assigned
    face_selector_ew(1) = 0
    face_selector_ns(1) = 0
    face_counter = (/ 1, 1, 0, 0 /)
    face_selector_ew_answer(1) = -1
    face_selector_ns_answer(1) = -1
    face_counter_answer = (/ 1, 1, 1, 1 /)

    call compute_face_selector( face_selector_ew, &
                                face_selector_ns, &
                                face_counter,     &
                                ndf_w3,           &
                                undf_w3,          &
                                map_w3,           &
                                ndf_w2h,          &
                                undf_w2h,         &
                                map_w2h )

    ! Check values!
    @assertEqual( face_selector_ew_answer, face_selector_ew )
    @assertEqual( face_selector_ns_answer, face_selector_ns )
    @assertEqual( face_counter_answer, face_counter )

    ! Test 5 -------------------------------------------------------------------
    ! No faces are yet assigned, all should become assigned
    face_selector_ew(1) = 0
    face_selector_ns(1) = 0
    face_counter = (/ 0, 0, 0, 0 /)
    face_selector_ew_answer(1) = 2
    face_selector_ns_answer(1) = 2
    face_counter_answer = (/ 1, 1, 1, 1 /)

    call compute_face_selector( face_selector_ew, &
                                face_selector_ns, &
                                face_counter,     &
                                ndf_w3,           &
                                undf_w3,          &
                                map_w3,           &
                                ndf_w2h,          &
                                undf_w2h,         &
                                map_w2h )

    ! Check values!
    @assertEqual( face_selector_ew_answer, face_selector_ew )
    @assertEqual( face_selector_ns_answer, face_selector_ns )
    @assertEqual( face_counter_answer, face_counter )

    deallocate(map_w3)
    deallocate(map_w2h)
    deallocate(face_selector_ew)
    deallocate(face_selector_ns)
    deallocate(face_counter)
    deallocate(face_selector_ew_answer)
    deallocate(face_selector_ns_answer)
    deallocate(face_counter_answer)

  end subroutine test_compute_face_selector

end module face_selector_support_mod_test
